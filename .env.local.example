# ─────────────────────────────────────────────────────────────
# RivHeal Website — Environment Variables
# Copy this file to .env.local and fill in the values.
# These MAIL_* vars are intentionally identical to rivheal-api/.env
# so both apps share the same SMTP credentials.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── SMTP (same values as rivheal-api) ────────────────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASSWORD=your_sendgrid_api_key
MAIL_FROM=noreply@rivheal.com
MAIL_FROM_NAME=RivHeal

# Where to deliver incoming contact/demo request emails
ADMIN_EMAIL=admin@rivheal.com

# ── Public API URL ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.rivheal.com/api/v1
