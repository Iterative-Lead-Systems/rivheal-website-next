# ─────────────────────────────────────────────────────────────
# RivHeal Website — Environment Variables
# Copy this file to .env.local and fill in the values.
# Email is handled by rivheal-api — no SMTP config needed here.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Backend API URL ──────────────────────────────────────────
# Contact and demo-request forms POST to this API.
NEXT_PUBLIC_API_URL=https://api.rivheal.com/api/v1
